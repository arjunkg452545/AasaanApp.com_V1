import React, { useState, useEffect } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import api from '../utils/api';
import { Button } from '../components/ui/button';
import { toast } from 'sonner';
import { ArrowLeft, RefreshCw } from 'lucide-react';

export default function QRDisplay() {
  const { meetingId } = useParams();
  const [qrImage, setQrImage] = useState(null);
  const [loading, setLoading] = useState(true);
  const [refreshing, setRefreshing] = useState(false);
  const navigate = useNavigate();

  const loadQR = async () => {
    try {
      const response = await api.get(`/admin/meetings/${meetingId}/qr`, {
        responseType: 'blob'
      });
      const imageUrl = URL.createObjectURL(response.data);
      setQrImage(imageUrl);
      setRefreshing(false);
    } catch (error) {
      toast.error('Failed to load QR code');
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    loadQR();
    
    // Auto-refresh every 10 seconds
    const interval = setInterval(() => {
      setRefreshing(true);
      loadQR();
    }, 10000);

    return () => clearInterval(interval);
  }, [meetingId]);

  return (
    <div className="min-h-screen bg-slate-900 flex flex-col items-center justify-center p-4 relative overflow-hidden">
      {/* Animated background */}
      <div className="absolute inset-0 opacity-10">
        <div className="absolute top-0 left-0 w-96 h-96 bg-[#CF2030] rounded-full blur-3xl animate-pulse"></div>
        <div className="absolute bottom-0 right-0 w-96 h-96 bg-[#005596] rounded-full blur-3xl animate-pulse" style={{animationDelay: '1s'}}></div>
      </div>

      <Button
        data-testid="back-btn"
        variant="outline"
        onClick={() => navigate('/admin/meetings')}
        className="absolute top-8 left-8 z-20 bg-white"
      >
        <ArrowLeft className="h-4 w-4 mr-2" />
        Back
      </Button>

      <div className="text-center mb-8 relative z-10">
        <h1 className="text-4xl font-bold text-white mb-2">Scan QR Code</h1>
        <p className="text-slate-300">for Attendance</p>
        {refreshing && (
          <div className="flex items-center justify-center gap-2 mt-4 text-[#CF2030]">
            <RefreshCw className="h-4 w-4 animate-spin" />
            <span className="text-sm">Refreshing...</span>
          </div>
        )}
      </div>

      {loading ? (
        <div className="bg-white p-12 rounded-2xl shadow-2xl">
          <div className="h-96 w-96 flex items-center justify-center">
            <div className="animate-spin rounded-full h-16 w-16 border-b-2 border-[#CF2030]"></div>
          </div>
        </div>
      ) : (
        <div 
          data-testid="qr-canvas"
          className="bg-white p-8 rounded-2xl shadow-2xl max-w-md w-full aspect-square flex items-center justify-center relative z-10 ring-4 ring-[#CF2030]/50"
        >
          {qrImage && (
            <img 
              src={qrImage} 
              alt="QR Code" 
              className="w-full h-full object-contain"
            />
          )}
        </div>
      )}

      <div className="mt-8 text-center relative z-10">
        <p className="text-white text-sm">QR code refreshes every 10 seconds</p>
        <p className="text-slate-400 text-xs mt-2">Meeting ID: {meetingId}</p>
      </div>
    </div>
  );
}